# ──────────────────────────────────────────────────────────────────────────────
# Pulse ERP — Backend Environment Template
# Copy this file to .env and fill in real values. NEVER commit .env files.
# ──────────────────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────────────────
# Option A: Full connection URL (Neon / Supabase / Railway)
# DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Option B: Individual fields (local Postgres)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=Pulse
DB_USER=postgres
DB_PASSWORD=                          # REQUIRED — no default

# ── Auth ──────────────────────────────────────────────────────────────────────
# REQUIRED. Production: minimum 32 chars, random, kept in a secrets manager.
JWT_SECRET=                           # REQUIRED — generate with: openssl rand -hex 32

# AES-256-GCM field encryption key — REQUIRED in production (server refuses to start without it).
# Must be exactly 32 characters. Generate with: node -e "console.log(require('crypto').randomBytes(24).toString('base64').slice(0,32))"
ENCRYPTION_KEY=                       # REQUIRED in production

# ── Server ────────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development                  # development | production | test

# ── CORS ─────────────────────────────────────────────────────────────────────
# REQUIRED in production. Without this the server refuses to start.
# Set to your deployed frontend origin (no trailing slash).
# FRONTEND_URL=https://your-app.vercel.app

# ── Authorization ─────────────────────────────────────────────────────────────
# Fail CLOSED when no role_permissions row exists for a (module, role) pair.
# Leave unset and an unseeded module is reachable by EVERY authenticated user.
# Enabled in production as of migration 20260719000001. If it produces a 403,
# seed the missing pair — do not disable the flag.
# PERMISSION_STRICT=true

# ── Rate limiting ─────────────────────────────────────────────────────────────
# Number of proxy hops in front of this process. Every rate limiter keys on
# req.ip, which Express only derives from X-Forwarded-For when this is set.
#   Too low  → all users share one bucket (the platform proxy's IP) and the
#              global limiter locks everyone out at once.
#   Too high → clients can forge X-Forwarded-For and bypass every limiter.
# Render and Railway put exactly one proxy in front of you, which is the
# production default. Raise it only if you add a CDN or your own load balancer.
# TRUST_PROXY_HOPS=1

# Global backstop — generous on purpose; it sheds scripted floods, it is not
# per-endpoint policy. /api/health is always exempt.
# GLOBAL_RL_MAX=300                   # requests per window per IP
# GLOBAL_RL_WINDOW_MS=60000           # 1 minute

# Auth endpoints (/login, /forgot-password, /verify-otp, /reset-password, /google)
# AUTH_RL_MAX=15
# AUTH_RL_WINDOW_MS=900000            # 15 minutes

# ── Monitoring ────────────────────────────────────────────────────────────────
# healthMonitor writes DB latency / memory / uptime to the health_checks table
# every 5 minutes, plus once ~10s after boot. Without persistence these numbers
# were logged and discarded, so "did latency degrade under load?" could not be
# answered after the fact.
# HEALTH_RETENTION_DAYS=90            # rows older than this are pruned hourly

# Row-count observability (see middlewares/responseCap.js)
# RESPONSE_ROW_CAP=2000               # hard ceiling; array responses truncate above this
# RESPONSE_ROW_OBSERVE=100            # log row counts at/above this WITHOUT truncating,
#                                     # so growth is visible long before the cap trips

# ── Logging ───────────────────────────────────────────────────────────────────
# LOG_LEVEL=info                      # error | warn | info | debug
# LOG_TO_FILE=true                    # append structured logs to logs/

# ── Observability ─────────────────────────────────────────────────────────────
# Slack / Discord / PagerDuty incoming-webhook URL for operational alerts
# ALERT_WEBHOOK_URL=https://hooks.slack.com/services/...
# DB latency threshold (ms) before a "slow" alert fires (two consecutive checks)
# ALERT_THRESHOLD_MS=800
# RSS memory threshold (MB) before a memory-pressure alert fires (Render free = 512 MB)
# MEMORY_ALERT_MB=450
# Write JSONL structured logs to logs/access.log, logs/errors.log, logs/health.log
# LOG_TO_FILE=true

# ── Email / SMTP ──────────────────────────────────────────────────────────────
# Shared transport for: password-reset OTP, e-signature signing invites,
# signer OTP codes, and reminders (utils/mailer.js).
# Required in production for these emails to actually deliver.
# In development, if SMTP_HOST is unset, the OTP / signing link is logged to the
# console instead (the flow still works — nothing is sent over the wire).
#
# Gmail example: SMTP_HOST=smtp.gmail.com  SMTP_PORT=587  SMTP_USER=you@gmail.com
#                SMTP_PASS=<app-password>  SMTP_FROM="Pulse ERP <you@gmail.com>"
#
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_SECURE=false                   # true for port 465 (implicit TLS), false for 587 (STARTTLS)
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=Pulse ERP <noreply@yourcompany.com>

# ── Payments / Razorpay ───────────────────────────────────────────────────────
# Enables live payment-on-sign (e-signature) and other Razorpay checkout flows.
# When BOTH keys are unset in development, payment is DEV-SIMULATED (no real
# charge) so the signing flow still completes. In production (NODE_ENV=production)
# the payment endpoints return 503 until these are configured.
# Get keys from the Razorpay Dashboard → Settings → API Keys.
#
# RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxx
# RAZORPAY_KEY_SECRET=
# Webhook signing secret (Dashboard → Settings → Webhooks) — verifies inbound
# payment webhooks at POST /api/webhooks. Required only if you enable webhooks.
# RAZORPAY_WEBHOOK_SECRET=

# ── Feature Flags ─────────────────────────────────────────────────────────────
# Convention: opt-out — omit the variable (or set to anything except "false") to ENABLE.
# Set to the exact string "false" to disable. All flags default to ENABLED.
#
# Disabling a flag restores pre-engine passthrough behavior:
#   WORKFLOW_ENGINE_ENABLED=false    → initiateWorkflow returns null (passthrough),
#                                      advanceWorkflow is a no-op, status queries return null/[].
#   RULE_ENGINE_ENABLED=false        → evaluateRules / checkInventoryRules return [] (no alerts).
#   VALIDATION_ENGINE_ENABLED=false  → validate / validateField return { valid: true, errors: [] }.
#   NOTIFICATION_ENGINE_ENABLED=false→ notifyWorkflowEvent is a silent no-op; no DB inserts.
#
WORKFLOW_ENGINE_ENABLED=true
RULE_ENGINE_ENABLED=true
VALIDATION_ENGINE_ENABLED=true
NOTIFICATION_ENGINE_ENABLED=true

# ── File Storage ───────────────────────────────────────────────────────────────
# STORAGE_PROVIDER controls where uploaded files are saved.
#   local  (default) — saved to /backend/uploads/ on disk. Fine for development
#                      and single-instance deploys, but files are lost on redeploy.
#   s3     — AWS S3. Set AWS_* vars below.
#   r2     — Cloudflare R2 (S3-compatible). Set AWS_* vars + AWS_S3_ENDPOINT.
#
# STORAGE_PROVIDER=local

# AWS S3 / Cloudflare R2 credentials (required when STORAGE_PROVIDER=s3 or r2)
# AWS_BUCKET_NAME=your-bucket-name
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1

# For Cloudflare R2 only — your account endpoint:
# AWS_S3_ENDPOINT=https://<ACCOUNT_ID>.r2.cloudflarestorage.com

# Public base URL files are served from (CDN / bucket public URL).
# Defaults to https://<bucket>.s3.<region>.amazonaws.com if not set.
# STORAGE_BASE_URL=https://assets.yourdomain.com

# ── Backup ─────────────────────────────────────────────────────────────────────
# Off-site DB backups — set BACKUP_S3_BUCKET to enable S3 upload.
# Uses the same AWS credentials as STORAGE_PROVIDER=s3 above.
# BACKUP_S3_BUCKET=pulse-db-backups
# BACKUP_S3_REGION=ap-south-1          # default: ap-south-1 (Mumbai)
# BACKUP_S3_STORAGE_CLASS=STANDARD_IA  # default: STANDARD_IA (cheaper for infrequent reads)

# Daily backup cron schedule (UTC cron syntax). Default: 02:00 IST = 20:30 UTC.
# BACKUP_CRON_SCHEDULE=30 20 * * *

# How many daily backup files to keep locally (default: 7).
# BACKUP_RETAIN_DAYS=7

# Set to a separate Postgres DB name to enable full restore drill in --drill mode.
# TEST_DB_NAME=Pulse_test

# ─── Mobile push notifications (optional) ─────────────────────────────────────
# Consumed by src/modules/notifications/services/pushSender.js. Leave unset to
# disable push (the app degrades gracefully — notifications stay in-app only).
#
# FCM (Android + web) — HTTP v1. From a Firebase service-account JSON:
#   FCM_PROJECT_ID   = the "project_id"
#   FCM_CLIENT_EMAIL = the "client_email"
#   FCM_PRIVATE_KEY  = the "private_key" (keep the literal \n escapes on one line)
# FCM_PROJECT_ID=your-firebase-project-id
# FCM_CLIENT_EMAIL=firebase-adminsdk-xxxx@your-project.iam.gserviceaccount.com
# FCM_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIE...\n-----END PRIVATE KEY-----\n"
#
# APNs (iOS) — token auth. From an Apple .p8 auth key:
#   APNS_KEY_ID      = the 10-char Key ID
#   APNS_TEAM_ID     = your 10-char Apple Team ID
#   APNS_PRIVATE_KEY = the .p8 contents (literal \n escapes on one line)
#   APNS_BUNDLE_ID   = com.manifest.pulse (must match capacitor.config.ts appId)
#   APNS_PRODUCTION  = false for the sandbox, true for the App Store build
# APNS_KEY_ID=ABC1234DEF
# APNS_TEAM_ID=TEAM123456
# APNS_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIGT...\n-----END PRIVATE KEY-----\n"
# APNS_BUNDLE_ID=com.manifest.pulse
# APNS_PRODUCTION=false

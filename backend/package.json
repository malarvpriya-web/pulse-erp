{
  "name": "backend",
  "version": "1.0.0",
  "description": "Pulse ERP Backend",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "restore": "node scripts/db-restore.js",
    "backup": "node scripts/db-backup.js",
    "backup:drill": "node scripts/db-backup.js --drill",
    "backup:list": "node scripts/db-backup.js --list",
    "migrate": "node -e \"import('./src/config/migrations.js').then(m=>m.runMigrations())\"",
    "migrate:rollback": "node -e \"import('./src/config/migrations.js').then(m=>m.rollbackLast())\"",
    "migrate:status": "node -e \"import('./src/config/migrations.js').then(m=>m.migrationStatus())\"",
    "migrate:repair-checksums": "node -e \"import('./src/config/migrations.js').then(m=>m.repairChecksums())\"",
    "generate-baseline": "node scripts/generate-baseline.js",
    "pre-deploy": "node scripts/pre-deploy.js",
    "post-deploy": "node scripts/post-deploy.js",
    "deploy": "npm run pre-deploy && npm run migrate && npm run post-deploy",
    "smoke:prod": "node scripts/smoke-prod.js",
    "smoke:access": "node scripts/smoke-employee-access.js",
    "test:phase3": "vitest run src/__tests__/phase3.test.js",
    "gate:phase3": "node scripts/phase3-gate.js",
    "gate:phase3:only": "node scripts/phase3-gate.js --phase3-only"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1049.0",
    "bcrypt": "^6.0.0",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "googleapis": "^171.4.0",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.0.2",
    "node-cron": "^4.2.1",
    "node-zklib": "^1.3.0",
    "nodemailer": "^8.0.7",
    "pdf-lib": "^1.17.1",
    "pdfkit": "^0.15.2",
    "pg": "^8.18.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "nodemon": "^3.1.11",
    "supertest": "^7.2.2",
    "vitest": "^4.1.5"
  }
}

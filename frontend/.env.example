# ──────────────────────────────────────────────────────────────────────────────
# Pulse ERP — Frontend Environment Template
# Copy this file to .env.local for local dev, .env.production for prod builds.
# Vite only exposes variables prefixed with VITE_ to the browser bundle.
# NEVER put secrets here — all values are visible in the built JS bundle.
# ──────────────────────────────────────────────────────────────────────────────

# Backend API base URL (must end without trailing slash)
# Development: leave unset — vite proxy (/api → localhost:5000) handles it
# Production: set to the full backend origin
# VITE_API_URL=https://api.your-app.com/api

# App metadata (safe to expose)
# VITE_APP_NAME=Pulse ERP
# VITE_APP_VERSION=1.0.0

# Google Drive root folder for HR documents (HR → Downloads page)
# Set to the sharing URL of your Google Drive HR documents folder
# VITE_DOCUMENTS_BASE_URL=https://drive.google.com/drive/folders/YOUR_FOLDER_ID
